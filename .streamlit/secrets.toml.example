# ============================================================
# Streamlit Cloud シークレット設定テンプレート
# ============================================================
# 使い方:
#   【Streamlit Cloud】
#     管理画面 → App Settings → Secrets に以下を貼り付け
#   【ローカル開発】
#     このファイルをコピーして .streamlit/secrets.toml を作成
#     （git にはコミットしないこと！）
# ============================================================

GEMINI_API_KEY = "your_gemini_api_key_here"
